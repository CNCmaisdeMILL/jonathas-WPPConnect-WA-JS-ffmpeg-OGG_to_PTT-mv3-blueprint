{
  "manifest_version": 3,
  "name": "PTT Stealth - Extensão de Teste",
  "version": "1.0.0",
  "description": "Arrasta, converte e envia Notas de Voz (PTT) perfeitas no WhatsApp Web.",
  "permissions": ["offscreen", "storage", "tabs", "activeTab", "scripting"],
  "host_permissions": ["https://web.whatsapp.com/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "wppconnect.js", 
        "injected.js", 
        "db-utility.js", 
        "offscreen.html", 
        "offscreen.js", 
        "ffmpeg/*"
      ],
      "matches": ["https://web.whatsapp.com/*"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}